{
  "entities": {
    "ArcheryEvent": {
      "title": "Archery Event",
      "description": "Details of an archery competition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "ACTIVE", "COMPLETED", "DELETED"] },
        "registrationCount": { "type": "integer" }
      },
      "required": ["name", "status"]
    },
    "Profile": {
      "title": "User Profile",
      "description": "User registration and role data",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/events": {
      "schema": "ArcheryEvent",
      "description": "Collection of archery events"
    },
    "/profiles": {
      "schema": "Profile",
      "description": "User profile data"
    },
    "/systemConfigs": {
      "schema": "object",
      "description": "System-wide configurations"
    }
  }
}
