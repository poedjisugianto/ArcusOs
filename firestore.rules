rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'poedji.sugianto@gmail.com' ||
        request.auth.token.email == 'admin@arcus.id' ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['SUPERADMIN', 'MASTER_ADMIN'])
      );
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'poedji.sugianto@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Profiles ---
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['id', 'email', 'name']) &&
                      incoming().id == userId &&
                      // Prevent self-elevating to admin on creation
                      (incoming().role == 'PARTICIPANT' || incoming().role == 'ORGANIZER' || !('role' in incoming()));
      allow update: if (isOwner(userId) || isAdmin()) &&
                      // If user is non-admin, they can't change their role
                      (isAdmin() || !incoming().diff(existing()).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if true; // Public for browsing events and live scores
      allow create: if isSignedIn() && (incoming().ownerId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    // --- System Configs ---
    match /systemConfigs/{configId} {
      allow read: if true; // Public for maintenance mode and global fees
      allow write: if isAdmin();
    }
  }
}
