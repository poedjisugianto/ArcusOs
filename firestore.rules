rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. PUBLIC EVENTS (Move to top for priority)
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Izinkan Admin berdasarkan email atau role di profile
      return isSignedIn() && (
        request.auth.token.email == 'poedji.sugianto@gmail.com' ||
        request.auth.token.email == 'admin@arcus.id' ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['SUPERADMIN', 'ADMIN', 'MASTER_ADMIN', 'superadmin'])
      );
    }

    function isEventOwner(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return isSignedIn() && (
        eventData.ownerId == request.auth.uid || 
        (eventData.data != null && eventData.data.ownerId == request.auth.uid)
      );
    }

    // --- 1. Profiles ---
    match /profiles/{userId} {
      allow get: if isSignedIn(); // User bisa melihat profile rekannya
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- 2. Events & Scoring ---
    match /events/{eventId} {
      // PUBLIK: Bisa melihat semua data event (skor, pendaftaran terverifikasi, dll)
      // allow read covers get and list
      allow read: if true;
      
      // ADMIN: Kontrol penuh
      allow create: if isSignedIn();
      allow update: if isAdmin() || isEventOwner(eventId);
      allow delete: if isAdmin();

      // Pendaftaran Online (Submissions)
      match /submissions/{subId} {
        allow read, create: if true; 
        allow update, delete: if isAdmin() || isEventOwner(eventId);
      }

      // Shards
      match /shards/{shardId} {
        allow read, write: if true;
      }
    }

    // Jalur warisan (hanya untuk keamanan tambahan)
    match /events/{document=**} {
      allow read: if true;
    }

    // --- 3. System Configs ---
    match /systemConfigs/{configId} {
      allow read: if true; // Publik perlu baca info biaya & kontak
      allow write: if isAdmin();
    }

    // --- 4. Utils ---
    match /test/connection {
      allow read: if true;
    }
  }
}
