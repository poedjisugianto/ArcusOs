rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'poedji.sugianto@gmail.com' ||
        request.auth.token.email == 'admin@arcus.id' ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.data.role in ['SUPERADMIN', 'MASTER_ADMIN', 'superadmin'])
      );
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'poedji.sugianto@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Profiles ---
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && (
                      isAdmin() || (
                        incoming().keys().hasAll(['id', 'data']) &&
                        incoming().id == userId &&
                        // Allow basic roles on creation
                        (incoming().data.role == 'PARTICIPANT' || incoming().data.role == 'ORGANIZER' || !('role' in incoming().data))
                      )
                    );
      allow update: if (isOwner(userId) || isAdmin()) &&
                      // If user is non-admin, they can't change their role
                      (isAdmin() || 
                       !('data' in incoming()) || 
                       !('data' in existing()) ||
                       !('role' in incoming().data) ||
                       !('role' in existing().data) ||
                       incoming().data.role == existing().data.role);
      allow delete: if isAdmin();
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if true; // Public for browsing events and live scores
      allow create: if isSignedIn() && (
                      isAdmin() || 
                      (incoming().userId == request.auth.uid) || 
                      (incoming().ownerId == request.auth.uid)
                    );
      allow update: if (isSignedIn() && (
                      isAdmin() || 
                      (existing().userId == request.auth.uid) || 
                      (existing().ownerId == request.auth.uid)
                    )) || (
                      // PUBLIC REGISTRATION HOOK: Allow public to add registrations via arrayUnion safely
                      // We limit what they can touch
                      incoming().diff(existing()).affectedKeys().hasOnly(['data', 'updatedAt']) &&
                      incoming().data.keys().hasAll(existing().data.keys()) &&
                      // Basic check: they cannot decrease the count of archers or registrations
                      incoming().data.registrations.size() >= existing().data.registrations.size() &&
                      incoming().data.archers.size() >= existing().data.archers.size()
                    );
      allow delete: if isSignedIn() && (
                      isAdmin() || 
                      (existing().userId == request.auth.uid) || 
                      (existing().ownerId == request.auth.uid)
                    );

      // Subcollection for more reliable public registrations
      match /submissions/{subId} {
        allow read: if true;
        allow create: if true; // OPEN FOR PUBLIC REGISTRATION
        allow update, delete: if isAdmin() || (isSignedIn() && existing().email == request.auth.token.email);
      }
    }

    // --- System Configs ---
    match /systemConfigs/{configId} {
      allow read: if true; // Public for maintenance mode and global fees
      allow write: if isAdmin();
    }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }
  }
}
