rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'poedji.sugianto@gmail.com' ||
        request.auth.token.email == 'admin@arcus.id' ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.data.role in ['SUPERADMIN', 'MASTER_ADMIN', 'ADMIN', 'superadmin'])
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isPublicRegistration() {
      // Allow public update of registrations array IF it's a valid increment
      return incoming().diff(existing()).affectedKeys().hasOnly(['data', 'updatedAt']) &&
             incoming().data.registrations.size() > existing().data.registrations.size();
    }

    // --- Profiles ---
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isAdmin() || 
                      (isSignedIn() && (existing().userId == request.auth.uid || existing().ownerId == request.auth.uid)) ||
                      isPublicRegistration();
      allow delete: if isAdmin() || 
                      (isSignedIn() && (existing().userId == request.auth.uid || existing().ownerId == request.auth.uid));

      match /submissions/{subId} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }

      match /shards/{shardId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/events/$(eventId)).data.userId == request.auth.uid || get(/databases/$(database)/documents/events/$(eventId)).data.ownerId == request.auth.uid));
      }
    }

    // --- System Configs ---
    match /systemConfigs/{configId} {
      allow read: if true; // Public for maintenance mode and global fees
      allow write: if isAdmin();
    }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }
  }
}
